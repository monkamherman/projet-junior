# ===========================================
# Configuration pour le déploiement (docker-compose)
# Copier vers .env et adapter les valeurs
# ===========================================

# Base de données MongoDB (utilisée par le container mongodb ET pour DATABASE_URL)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change_this_password
MONGO_INITDB_DATABASE=projet_junior

# DATABASE_URL est construite automatiquement par docker-compose via les variables ci-dessus
# Si vous overridez, utilisez: mongodb://user:pass@mongodb:27017/dbname?authSource=admin

# Configuration du serveur
NODE_ENV=production
JWT_SECRET=your_secure_jwt_secret_key_here
JWT_REFRESH_SECRET=your_refresh_jwt_secret_key_here

# URL du client (pour CORS) - doit correspondre au domaine configuré dans NPM
CLIENT_URL=https://votre-domaine.com
